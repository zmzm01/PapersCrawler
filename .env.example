# PapersCrawler 密钥配置
# 复制此文件为 .env，填写真实值后保存
# .env 已加入 .gitignore，不会被提交

# CrossRef API 礼貌邮箱（必填）
CROSSREF_MAILTO=your_email@example.com

# MinerU PDF 解析 Token（从 https://mineru.net 获取）
MINERU_TOKEN=your_mineru_token_here

# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# === SMTP 邮件推送（可选，不配置则跳过 Phase H）===
# SMTP 服务器地址
# SMTP_HOST=smtp.163.com
# SMTP 端口: TLS=587, SSL=465
# SMTP_PORT=465
# use_tls=false 表示 SSL 直连（端口 465）；true 表示 STARTTLS（端口 587）
# SMTP_USE_TLS=false
# SMTP 登录用户名（通常是邮箱地址）
# SMTP_USERNAME=your_email@example.com
# SMTP 授权码（非邮箱登录密码！）
# SMTP_PASSWORD=your_auth_code
# 发件人地址
# SMTP_FROM_ADDR=your_email@example.com
# 收件人地址列表（多个用逗号分隔）
# SMTP_TO_ADDRS=colleague1@example.com,colleague2@example.com
